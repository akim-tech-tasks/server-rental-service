{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=server-rental.db"
  },
  "ServerRental": {
    "BootDurationMinutes": 5,
    "LeaseDurationMinutes": 20,
    "LifecycleCheckIntervalSeconds": 5,
    "InitialServers": [
      {
        "OperatingSystem": "Ubuntu 22.04",
        "MemoryGb": 16,
        "DiskGb": 200,
        "CpuCores": 8,
        "InitiallyPoweredOn": true
      },
      {
        "OperatingSystem": "Windows Server 2022",
        "MemoryGb": 32,
        "DiskGb": 500,
        "CpuCores": 16,
        "InitiallyPoweredOn": false
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
